{
  "manifest_version": 3,
  "name": "CRM Helper Extension",
  "version": "1.0",
  "description": "Capture LinkedIn profile/message data or via PDF upload fallback.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://linkedin.com/*",
    "https://*.linkedin.com/*",
    "http://localhost:8000/*",
    "https://localhost:8000/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "popup.html" },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/*",
        "https://linkedin.com/*",
        "https://*.linkedin.com/*"
      ],
      "js": ["content.js"]
    }
  ]
}
